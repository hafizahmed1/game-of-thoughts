# =========================
# Experiment outputs (IMPORTANT)
# =========================

# ❌ Ignore heavy raw outputs
results/prompts/
results/responses/

# ❌ Ignore all tables by default
results/tables/*

# ✅ Allow ONLY final important tables
!results/tables/all_simulation_results.csv
!results/tables/all_experiments_summary_latest.csv
!results/tables/all_experiments_summary_latest.json

# ❌ Ignore figures unless needed
results/figures/

# ❌ Ignore all analysis first
results/analysis/*

# ✅ Keep only useful analysis outputs
!results/analysis/*.csv
!results/analysis/*.md
!results/analysis/*.png

